# ─── EventScope configuration ───────────────────────────────────────────────
# Copy to `.env` and fill in. Every live integration is OFF by default so the
# pipeline and tests run fully offline with zero credentials.

# --- Geographic pilot scope (Fase 0: Adrogué / Zona Sur GBA) ---
EVENTSCOPE_PILOT_LAT=-34.7998
EVENTSCOPE_PILOT_LNG=-58.3897
EVENTSCOPE_PILOT_RADIUS_KM=15

# --- Database ---
# Default is a local SQLite file (no external dependency). For production use
# the PostGIS docker-compose service:
#   EVENTSCOPE_DATABASE_URL=postgresql+psycopg://eventscope:eventscope@localhost:5432/eventscope
EVENTSCOPE_DATABASE_URL=sqlite:///./data/eventscope.db

# --- LLM extraction (provider-agnostic) ---
# Provider: "stub" (offline heurísticos, default), "gemini", o "openai".
# Gemini Flash y GPT-4o-mini son baratos y suficientes para extracción.
EVENTSCOPE_LLM_PROVIDER=stub
EVENTSCOPE_LLM_API_KEY=
EVENTSCOPE_LLM_MODEL=
# Ejemplos:
#   EVENTSCOPE_LLM_PROVIDER=gemini
#   EVENTSCOPE_LLM_API_KEY=AIza...
#   EVENTSCOPE_LLM_MODEL=gemini-2.0-flash
#
#   EVENTSCOPE_LLM_PROVIDER=openai
#   EVENTSCOPE_LLM_API_KEY=sk-...
#   EVENTSCOPE_LLM_MODEL=gpt-4o-mini

# --- Embeddings para dedup ---
# "stub" (hashing offline, default) o "sentence-transformers" (mejor calidad).
EVENTSCOPE_EMBEDDING_PROVIDER=stub

# --- Geocoding ---
# "null" (default, no inventa coordenadas) o "nominatim" (OSM, gratis).
# Nominatim: máx 1 req/s, requiere User-Agent descriptivo.
EVENTSCOPE_GEOCODER_PROVIDER=null
# EVENTSCOPE_GEOCODER_PROVIDER=nominatim
EVENTSCOPE_NOMINATIM_USER_AGENT=EventScope/0.1 (+https://eventscope.app)
EVENTSCOPE_NOMINATIM_URL=https://nominatim.openstreetmap.org

# --- Eventbrite (API oficial) ---
EVENTSCOPE_EVENTBRITE_TOKEN=

# --- Instagram oEmbed (Meta oEmbed Read API) ---
# Desde abril 2025 el endpoint sin auth fue removido. Se necesita token de app
# Meta con permiso `oembed_read`. Sin token: fallback a iframe embed público.
# IG es enriquecimiento (no discovery): se usa para resolver permalinks
# cosechados de las páginas de venues y gobierno.
EVENTSCOPE_IG_ACCESS_TOKEN=
